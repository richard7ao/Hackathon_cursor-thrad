# FairLet — environment template
# Copy to .env and fill in real values. Do not commit .env.

# ── Tavily (live listings, Equality Act citation, scam-listing scrape) ──
# Grab from the tavily.com channel in the hackathon Discord.
TAVILY_API_KEY=tvly-dev-REPLACE_ME

# ── Anthropic / Claude (policy judge LLM, Generate-Fresh-Probes button) ──
# https://console.anthropic.com — create an API key.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Overmind (supervision tracing wrapped around every gate call) ──
# Grab from the overmindlab.ai channel in the hackathon Discord.
# Console: https://console.overmindlab.ai
OVERMIND_API_KEY=REPLACE_ME

# ── Alpic (deploy + MCP routing) ──
# Usually handled by `alpic` CLI auth — only set this if your deploy flow needs it.
# Grab from the alpic.ai channel in the hackathon Discord.
ALPIC_API_KEY=REPLACE_ME
